// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Donor information
model Donor {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  donations     Donation[]
  subscriptions Subscription[]

  @@map("donors")
}

// Individual donations (one-time or part of subscription)
model Donation {
  id       String @id @default(uuid())
  donorId  String
  donor    Donor  @relation(fields: [donorId], references: [id], onDelete: Cascade)

  // Stripe identifiers
  stripePaymentIntentId String? @unique
  stripeSubscriptionId  String?

  // Donation details
  amount        Int    // Amount in cents
  currency      String @default("usd")
  frequency     String // 'once' | 'monthly' | 'yearly'

  causeId       String?
  causeName     String?

  feesCovered   Boolean @default(false)
  feeAmount     Int     @default(0) // Fee amount in cents

  status        String  // 'pending' | 'succeeded' | 'failed' | 'refunded'

  // Additional data
  metadata      Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([donorId])
  @@index([stripePaymentIntentId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@index([createdAt])
  @@map("donations")
}

// Recurring subscriptions
model Subscription {
  id       String @id @default(uuid())
  donorId  String
  donor    Donor  @relation(fields: [donorId], references: [id], onDelete: Cascade)

  // Stripe identifier
  stripeSubscriptionId String @unique

  // Subscription details
  amount    Int    // Amount in cents per billing cycle
  currency  String @default("usd")
  frequency String // 'monthly' | 'yearly'

  causeId   String?
  causeName String?

  status    String // 'active' | 'canceled' | 'past_due' | 'incomplete'

  // Billing period
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  canceledAt DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([donorId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@map("subscriptions")
}

// Webhook event tracking for idempotency
model WebhookEvent {
  id              String   @id @default(uuid())
  stripeEventId   String   @unique
  type            String   // Event type (e.g., 'payment_intent.succeeded')
  processed       Boolean  @default(false)
  processedAt     DateTime?

  createdAt       DateTime @default(now())

  @@index([stripeEventId])
  @@index([processed])
  @@map("webhook_events")
}

// User accounts (synced with Supabase Auth)
model User {
  id            String   @id // Matches Supabase Auth user ID
  email         String   @unique
  name          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  organizations UserOrganization[]

  @@map("users")
}

// Organizations (multi-tenant support)
model Organization {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique // URL-friendly identifier
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  users            UserOrganization[]
  widgets          WidgetConfig[]

  @@index([slug])
  @@map("organizations")
}

// Many-to-many relationship between Users and Organizations
model UserOrganization {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String   @default("admin") // 'admin' | 'member' | 'viewer'
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("user_organizations")
}

// Widget configuration for customization
model WidgetConfig {
  id                String   @id @default(uuid())
  siteId            String   @unique // Unique identifier for the widget
  organizationId    String   // NEW: Link to organization
  organizationName  String

  // Donation amounts configuration
  amounts           Json     // Array of {value, label, default}

  // Feature flags
  allowRecurring    Boolean  @default(true)
  allowCoverageFee  Boolean  @default(true)

  // Stripe fee configuration
  feePercentage     Float    @default(2.9)
  feeFixed          Int      @default(30) // in cents

  // Donation limits
  minAmount         Int      @default(100)  // in cents
  maxAmount         Int      @default(99999900) // in cents

  // Currency
  currency          String   @default("usd")

  // Causes/campaigns
  causes            Json?    // Array of {id, name, description}

  // Theme customization
  theme             Json?    // {mode, primaryColor, borderRadius}

  // Stripe Connect
  stripeConnectAccountId   String?  // Connected Stripe account ID
  stripeConnectOnboarded   Boolean  @default(false) // Onboarding complete
  platformFeePercentage    Float    @default(3.0) // Platform fee %

  // Metadata
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([isActive])
  @@index([organizationId])
  @@index([stripeConnectAccountId])
  @@map("widget_configs")
}
